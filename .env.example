# Seagnal AI Platform Environment Configuration

# Service Port
PORT=3000
NODE_ENV=development

# Development Flags (Enable local mock testing in AI Studio)
USE_MOCK_DATA=true
AUTH_REQUIRED=false
USE_MOCK_AUTH=true
CLOUD_SQL_ENABLED=false

# Google Cloud Platform Identification (Replace with real values post-export)
GCP_PROJECT_ID=
BIGQUERY_DATASET_ID=seagnal_ai
BIGQUERY_VESSELS_TABLE=vessels
BIGQUERY_MOVEMENTS_TABLE=vessel_movements
BIGQUERY_ALERTS_TABLE=alerts
BIGQUERY_ZONES_TABLE=maritime_zones

# WorkOS AuthKit Configuration
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
CSRF_SECRET=
WORKOS_ORGANIZATION_ID=

APP_BASE_URL=http://localhost:3000
WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Cloud SQL PostgreSQL Configuration
CLOUD_SQL_INSTANCE_CONNECTION_NAME=
CLOUD_SQL_DATABASE=
CLOUD_SQL_USER=
CLOUD_SQL_PASSWORD=

# Gemini AI API Configuration
GEMINI_API_KEY=
